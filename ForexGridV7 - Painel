   CriarTexto("txt_ask_val", x+50, y+170, DoubleToString(ask, _Digits), Cor_Texto, 9, "Courier New");
   CriarTexto("txt_bid_label", x+180, y+170, "Bid:", Cor_Texto_Sec, 8, "Arial");
   CriarTexto("txt_bid_val", x+215, y+170, DoubleToString(bid, _Digits), Cor_Texto, 9, "Courier New");
   
   // ═══ POSIÇÕES ═══
   int compras = ContarOrdens(POSITION_TYPE_BUY);
   int vendas = ContarOrdens(POSITION_TYPE_SELL);
   double lucro_posicoes = CalcularLucroEA();
   color cor_lucro = (lucro_posicoes >= 0) ? Cor_Positivo : Cor_Negativo;
   string sinal_lucro = (lucro_posicoes >= 0) ? "+" : "";
   
   CriarTexto("txt_posicoes_label", x+15, y+245, "POSIÇÕES (Venda bloqueia Compra)", Cor_Texto_Sec, 8, "Courier New");
   
   string status_compra = (vendas > 0) ? "⛔" : "▲";
   color cor_status_compra = (vendas > 0) ? clrGray : Cor_Positivo;
   
   CriarTexto("txt_compras_label", x+15, y+262, status_compra + " Compras: ", cor_status_compra, 9, "Courier New");
   CriarTexto("txt_compras_valor", x+105, y+262, IntegerToString(compras), Cor_Texto, 10, "Courier New");
   
