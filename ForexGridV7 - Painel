// Parâmetros de Entrada
input group "=== Estratégia de Compra (Grid) ==="
input double   Lote_Compra = 0.03;                   // Lote para ordens de compra
input int      Distancia_Grid_Compra = 1000;          // Distância entre compras (pontos)
input int      Take_Profit_Compra = 500;             // Take Profit compras (pontos)

input group "=== Estratégia de Venda (Grid) ==="
input double   Lote_Venda = 0.10;                    // Lote para ordem de venda
